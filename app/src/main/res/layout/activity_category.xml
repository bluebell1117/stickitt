<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF6E6">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_blueforhomepage"
        android:contentDescription="Back Button"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#193150" />

    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_blueforhomepage"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#8A8A8A" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Select 1 category"
            android:inputType="text"
            android:textColorHint="#9EB5D1"
            android:textSize="16sp" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/gridCategories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchContainer">

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="😊 Cute" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🐼 Animal" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🌌 Astronomy" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🎭 Meme" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🦖 Spooky" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🤖 Character" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🎶 Music" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="🎬 Movie" />

        <androidx.appcompat.widget.AppCompatButton
            style="@style/CategoryButtonStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="💬 Quotes" />
    </GridLayout>

    <FrameLayout
        android:id="@+id/blueCardBottom"
        android:layout_width="0dp"
        android:layout_height="380dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/betterblue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gridCategories">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/josefin_sans"
            android:text="Nothing to show..."
            android:textColor="#193150"
            android:textSize="16sp" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>